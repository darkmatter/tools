# Example rclone.conf for the `rclone-drive` / `rclone-google-drive` flake app.
#
# Copy this file locally, fill it in with a real Google Drive rclone remote,
# then encrypt it into the SOPS secret used by sops-nix.
#
# The flake wrapper defaults to this remote name:
#
#   darkmatter-google-drive
#
# If you change the section name below, pass that name as the second argument:
#
#   nix run github:darkmatter/nix#rclone-drive -- ~/Drive my-remote-name
#
# Recommended setup flow:
#
#   1. Run `rclone config` locally.
#   2. Create a Google Drive remote named `darkmatter-google-drive`.
#   3. Copy the generated remote block from your real rclone config.
#   4. Encrypt that block into `ops/secrets/secrets.sops.yaml` under:
#
#        darkmatter/sops/rclone.conf
#
# This example is intentionally not usable as-is.

[darkmatter-google-drive]
type = drive

# Optional but recommended for team/shared usage.
# Create OAuth credentials in Google Cloud and fill these in.
client_id = TODO_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
client_secret = TODO_GOOGLE_OAUTH_CLIENT_SECRET

# Common scopes:
#
#   drive              Full access to all files visible to the account.
#   drive.readonly     Read-only access.
#   drive.file         Access only to files created/opened by this app.
#
# For a mount that needs normal read/write behavior, use `drive`.
scope = drive

# OAuth token generated by `rclone config`.
# Replace this whole JSON value with the token from your real rclone config.
#
# Example shape only:
token = {"access_token":"TODO_ACCESS_TOKEN","token_type":"Bearer","refresh_token":"TODO_REFRESH_TOKEN","expiry":"1970-01-01T00:00:00.000000000Z"}

# Optional: set this when mounting a Shared Drive / Team Drive.
#
# You can find it by running:
#
#   rclone backend drives darkmatter-google-drive:
#
# team_drive = TODO_SHARED_DRIVE_ID

# Optional: restrict the remote to a folder inside My Drive or a Shared Drive.
#
# root_folder_id = TODO_FOLDER_ID
